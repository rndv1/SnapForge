@page
@model IndexModel

@{
    ViewData["Title"] = Model.Text.PageTitle;
    ViewData["Language"] = Model.Text.HtmlLang;
}

<div class="app-shell">
    <header class="topbar">
        <div>
            <span class="product-label">@Model.Text.ProductLabel</span>
            <h1>@Model.Text.MainHeading</h1>
        </div>
        <div class="topbar-actions">
            <nav class="language-switch" aria-label="Language">
                <a asp-page="/Index" asp-route-lang="ru" class="@(Model.CurrentLanguage == "ru" ? "is-active" : null)">RU</a>
                <a asp-page="/Index" asp-route-lang="en" class="@(Model.CurrentLanguage == "en" ? "is-active" : null)">EN</a>
            </nav>
            <a class="repo-link" href="https://github.com/rndv1/SnapForge">@Model.Text.GitHubLink</a>
        </div>
    </header>

    <main class="workspace">
        <section class="tool-panel" aria-labelledby="card-form-title">
            <div class="panel-heading">
                <h2 id="card-form-title">@Model.Text.CardSettings</h2>
                <span>@Model.SelectedPresetSize</span>
            </div>

            <form method="post" enctype="multipart/form-data" class="card-form">
                @Html.AntiForgeryToken()
                <input asp-for="Input.Language" type="hidden" />

                <div class="field">
                    <label asp-for="Input.Screenshot">@Model.Text.ScreenshotLabel</label>
                    <div class="dropzone" data-dropzone>
                        <input
                            asp-for="Input.Screenshot"
                            type="file"
                            accept="image/png,image/jpeg,image/webp,image/gif,image/bmp"
                            class="file-input"
                            data-file-input
                            aria-describedby="screenshot-file-state" />
                        <div class="dropzone-copy">
                            <strong>@Model.Text.DropScreenshot</strong>
                            <span id="screenshot-file-state" data-file-name data-empty-text="@Model.Text.NoFileSelected">@Model.Text.NoFileSelected</span>
                        </div>
                        <span class="file-action">@Model.Text.Browse</span>
                    </div>
                </div>

                <div class="field">
                    <label asp-for="Input.Title">@Model.Text.TitleLabel</label>
                    <input asp-for="Input.Title" autocomplete="off" />
                </div>

                <div class="field">
                    <label asp-for="Input.Subtitle">@Model.Text.SubtitleLabel</label>
                    <input asp-for="Input.Subtitle" autocomplete="off" />
                </div>

                <div class="field-row">
                    <div class="field">
                        <label asp-for="Input.Preset">@Model.Text.PresetLabel</label>
                        <select asp-for="Input.Preset" asp-items="Model.PresetOptions"></select>
                    </div>

                    <div class="field">
                        <label asp-for="Input.Theme">@Model.Text.ThemeLabel</label>
                        <select asp-for="Input.Theme" asp-items="Model.ThemeOptions"></select>
                    </div>
                </div>

                <div class="custom-options">
                    <div class="color-option">
                        <label class="checkbox-control">
                            <input asp-for="Input.UseCustomBackground" type="checkbox" />
                            <span>@Model.Text.CustomBackground</span>
                        </label>

                        <label class="color-picker">
                            <span>@Model.Text.ColorLabel</span>
                            <input asp-for="Input.BackgroundColor" type="color" />
                        </label>
                    </div>

                    <div class="padding-option">
                        <label class="checkbox-control">
                            <input asp-for="Input.UseCustomPadding" type="checkbox" />
                            <span>@Model.Text.CustomPadding</span>
                        </label>

                        <label class="number-picker">
                            <span>@Model.Text.PixelsLabel</span>
                            <input asp-for="Input.Padding" type="number" min="32" max="240" step="8" />
                        </label>
                    </div>
                </div>

                <button type="submit">@Model.Text.GenerateButton</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <p class="notice error" role="alert">@Model.ErrorMessage</p>
            }
            else if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <p class="notice success">@Model.SuccessMessage</p>
            }
        </section>

        <section class="preview-panel" aria-labelledby="preview-title">
            <div class="preview-heading">
                <div>
                    <span class="product-label">@Model.Text.PreviewLabel</span>
                    <h2 id="preview-title">@Model.PreviewTitle</h2>
                </div>

                @if (Model.Result is not null)
                {
                    <a class="download-link" href="@Model.ResultDataUrl" download="snapforge-card.png">@Model.Text.DownloadPng</a>
                }
            </div>

            <div class="preview-stage">
                <img src="@Model.PreviewImageSource" alt="@Model.PreviewImageAlt" />
            </div>

            <dl class="metadata">
                <div>
                    <dt>@Model.Text.MetadataPreset</dt>
                    <dd>@Model.DisplayPreset</dd>
                </div>
                <div>
                    <dt>@Model.Text.MetadataTheme</dt>
                    <dd>@Model.DisplayTheme</dd>
                </div>
                <div>
                    <dt>@Model.Text.MetadataBackground</dt>
                    <dd>@Model.DisplayBackground</dd>
                </div>
                <div>
                    <dt>@Model.Text.MetadataPadding</dt>
                    <dd>@Model.DisplayPadding</dd>
                </div>
                <div>
                    <dt>@Model.Text.MetadataSize</dt>
                    <dd>@Model.DisplaySize</dd>
                </div>
                <div>
                    <dt>@Model.Text.MetadataFile</dt>
                    <dd>@Model.DisplayFileSize</dd>
                </div>
            </dl>

            @if (Model.History.Count > 0)
            {
                <section class="history-panel" aria-labelledby="history-title">
                    <div class="history-heading">
                        <h2 id="history-title">@Model.Text.HistoryTitle</h2>
                        <span>@Model.History.Count</span>
                    </div>

                    <ol class="history-list">
                        @foreach (var item in Model.History)
                        {
                            <li>
                                <div class="history-copy">
                                    <strong>@item.Title</strong>
                                    <span>@item.CreatedAtLabel / @item.PresetName / @item.ThemeName / @Model.FormatBackground(item) / @Model.FormatPadding(item) / @item.SizeLabel</span>
                                </div>
                                <a class="history-download" href="@item.DataUrl" download="@item.DownloadFileName">PNG</a>
                            </li>
                        }
                    </ol>
                </section>
            }
        </section>
    </main>
</div>
